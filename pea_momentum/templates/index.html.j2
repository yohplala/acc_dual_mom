<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ page_title|default('PEA Accelerated Dual Momentum') }}</title>
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
  <style>
    :root {
      --bg: #0e1116;
      --panel: #161b22;
      --border: #30363d;
      --text: #e6edf3;
      --muted: #8b949e;
      --accent: #58a6ff;
      --positive: #3fb950;
      --negative: #f85149;
    }
    html, body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
      margin: 0;
      padding: 0;
    }
    .container { max-width: 1200px; margin: 0 auto; padding: 24px; }
    h1 { margin: 0 0 4px 0; font-size: 28px; }
    h2 { margin: 32px 0 12px 0; font-size: 20px; border-bottom: 1px solid var(--border); padding-bottom: 6px; }
    .subtitle { color: var(--muted); margin-bottom: 24px; font-size: 13px; }
    .panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 16px;
      margin-bottom: 16px;
    }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th, td { text-align: left; padding: 8px 12px; border-bottom: 1px solid var(--border); }
    th { color: var(--muted); font-weight: 500; text-transform: uppercase; font-size: 11px; letter-spacing: 0.5px; }
    th.sortable { cursor: pointer; user-select: none; }
    th.sortable:hover { color: var(--text); }
    th.sortable::after { content: " ⇅"; opacity: 0.3; }
    th.sortable.sort-asc::after { content: " ↑"; opacity: 1; color: var(--accent); }
    th.sortable.sort-desc::after { content: " ↓"; opacity: 1; color: var(--accent); }
    td.numeric { text-align: right; font-variant-numeric: tabular-nums; }
    .pos { color: var(--positive); }
    .neg { color: var(--negative); }
    .chart { height: 480px; }
    .chart-small { height: 320px; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .pill {
      display: inline-block;
      background: rgba(88, 166, 255, 0.15);
      color: var(--accent);
      padding: 2px 8px;
      border-radius: 12px;
      font-size: 11px;
      font-weight: 500;
    }
    /* weight-bracket colored chips for the signal table */
    .chip {
      display: inline-block;
      padding: 2px 8px;
      margin: 1px 4px 1px 0;
      border-radius: 4px;
      font-size: 12px;
      font-variant-numeric: tabular-nums;
      border: 1px solid transparent;
      background: rgba(255, 255, 255, 0.04);
      text-decoration: none;
    }
    a.chip { cursor: pointer; }
    a.chip:hover { filter: brightness(1.2); text-decoration: underline; }
    .chip-zero { color: var(--text); opacity: 0.45; }
    .chip-neutral { color: var(--muted); border-color: rgba(127, 137, 152, 0.35); background: rgba(127, 137, 152, 0.08); }
    .chip-low  { color: #f0b06b; border-color: rgba(240, 176, 107, 0.35); background: rgba(240, 176, 107, 0.10); }
    .chip-mid  { color: var(--positive); border-color: rgba(63, 185, 80, 0.40); background: rgba(63, 185, 80, 0.10); }
    .chip-high { color: #c98aff; border-color: rgba(201, 138, 255, 0.45); background: rgba(201, 138, 255, 0.12); }
    .chip-row { white-space: nowrap; }
    .chip-row + .chip-row { margin-top: 2px; }
    /* Inside table cells (signal table), stack chips vertically — one
       chip per line — so wide cells with many chips don't blow out the
       table width. The wrapper chip-row stays a flex container; chips
       inside become block-level. */
    td.chips .chip-row { display: flex; flex-direction: column; align-items: stretch; gap: 2px; }
    td.chips .chip { display: block; text-align: center; }
    td.chips { vertical-align: top; text-align: center; }
    th.chips { text-align: center; }
    .dash { color: var(--muted); opacity: 0.5; }
    /* Allocation cell shows top-N on line 1 + weighting rule on line 2. */
    td.alloc { line-height: 1.4; }
    /* Performance metrics + signal tables — center every cell + header */
    table.metrics th, table.metrics td { text-align: center; }
    table.signal th, table.signal td { text-align: center; }
    footer { margin-top: 48px; color: var(--muted); font-size: 12px; text-align: center; }
    nav {
      display: flex;
      justify-content: center;
      gap: 8px;
      flex-wrap: wrap;
      margin: 8px 0 24px 0;
    }
    nav a, nav .nav-current {
      display: inline-block;
      padding: 8px 18px;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: var(--panel);
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s, color 0.15s;
    }
    nav a { color: var(--accent); }
    nav a:hover { background: var(--bg); border-color: var(--accent); }
    nav .nav-current {
      background: var(--accent);
      color: var(--bg);
      border-color: var(--accent);
      cursor: default;
    }
    @media (max-width: 800px) { .grid-2 { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <div class="container">
    <h1>{{ page_title|default('PEA Accelerated Dual Momentum') }}</h1>
    <div class="subtitle">
      {%- if page_subtitle %}{{ page_subtitle }} · {% endif -%}
      {{ summary.n_strategies }} strategies · last update {{ summary.last_update }} ·
      data range {{ summary.data_start }} → {{ summary.data_end }}
    </div>
    <nav>
      {%- for link in nav_links|default([]) %}
        {%- if link.current %}
          <span class="nav-current">{{ link.label }}</span>
        {%- else %}
          <a href="{{ link.href }}">{{ link.label }}</a>
        {%- endif %}
      {%- else %}
        <a href="correlations.html">Correlation</a>
      {%- endfor %}
    </nav>

    {%- macro asset_chip(c, label) -%}
      {%- if c.url -%}
        <a class="chip chip-{{ c.bracket if c.bracket else 'neutral' }}" href="{{ c.url }}" target="_blank" rel="noopener" title="{{ c.name }}">{{ label }}</a>
      {%- else -%}
        <span class="chip chip-{{ c.bracket if c.bracket else 'neutral' }}" title="{{ c.name }}">{{ label }}</span>
      {%- endif -%}
    {%- endmacro -%}

    {#- Universe chip with current allocation overlaid: if the asset has a
        non-zero current weight, the chip text is "id pct%" with the
        weight-bracket coloring (low/mid/high). Otherwise the chip is plain
        (neutral, just the id). -#}
    {%- macro chip_with_current(c, current_by_id) -%}
      {%- set live = current_by_id.get(c.id) -%}
      {%- if live -%}
        {%- if c.url -%}
          <a class="chip chip-{{ live.bracket }}" href="{{ c.url }}" target="_blank" rel="noopener" title="{{ c.name }}">{{ c.id }} {{ live.pct }}%</a>
        {%- else -%}
          <span class="chip chip-{{ live.bracket }}" title="{{ c.name }}">{{ c.id }} {{ live.pct }}%</span>
        {%- endif -%}
      {%- else -%}
        {{- asset_chip(c, c.id) -}}
      {%- endif -%}
    {%- endmacro -%}

    <h2>Strategies &amp; latest signal</h2>
    <div class="panel">
      <table class="signal">
        <thead>
          <tr>
            <th class="sortable" data-sort="text">Strategy</th>
            <th class="sortable" data-sort="text">Cadence</th>
            <th class="sortable" data-sort="text" title="Score recipe: ADM = mean of multiple lookbacks (accelerated dual-momentum); DM = single-lookback dual-momentum; Buy & Hold = no scoring.">Scoring</th>
            <th class="sortable" data-sort="text" title="Allocation recipe: top-N (number of sleeves held) + weighting rule (equal = 1/N, score-prop = score-proportional). B&H = buy-and-hold static weights.">Allocation</th>
            <th class="numeric sortable sort-desc" data-sort="num" title="Compound Annual Growth Rate. Default sort key: rows are pre-sorted by CAGR desc; click any other sortable header to re-rank.">CAGR</th>
            <th class="sortable" data-sort="text">Last rebalance</th>
            <th class="chips" title="World + Cash sleeves with current allocation overlaid: id only when not held this period, id + pct% when held (color-coded by weight)">World<br>Cash</th>
            <th class="chips" title="US, Europe, Asia sleeves with current allocation overlaid: id only when not held this period, id + pct% when held (color-coded by weight). Order: US first, then Europe, then Asia">US<br>Europe<br>Asia</th>
            <th class="chips" title="Previous rebalance allocation, non-zero only, sorted by weight desc">Prev alloc</th>
          </tr>
        </thead>
        <tbody>
          {% for s in signals %}
          <tr>
            <td data-value="{{ s.name }}"><span class="pill">{{ s.name }}</span></td>
            <td data-value="{{ s.cadence }}">{{ s.cadence }}</td>
            <td data-value="{{ s.scoring }}">{{ s.scoring }}</td>
            <td class="alloc" data-value="{{ s.allocation_top }} {{ s.allocation_weight }}">{{ s.allocation_top }}{% if s.allocation_weight %}<br>{{ s.allocation_weight }}{% endif %}</td>
            <td class="numeric {{ 'pos' if s.cagr >= 0 else 'neg' }}" data-value="{{ s.cagr }}">{% if s.cagr == s.cagr and s.cagr != -1e308 %}{{ "%.2f%%"|format(s.cagr * 100) }}{% else %}—{% endif %}</td>
            <td data-value="{{ s.last_rebalance }}">{{ s.last_rebalance }}</td>
            {# World + Cash consolidated, with current allocation overlaid. #}
            <td class="chips">
              {% set world_cash = s.universe_buckets["world"] + s.universe_buckets["cash"] %}
              {% if world_cash %}
              <div class="chip-row">
                {% for c in world_cash %}{{ chip_with_current(c, s.current_alloc_by_id) }}{% endfor %}
              </div>
              {% else %}
              <span class="dash">—</span>
              {% endif %}
            </td>
            {# US + Europe + Asia consolidated, with current allocation overlaid.
               Order: us, europe, asia. #}
            <td class="chips">
              {% set risky = s.universe_buckets["us"] + s.universe_buckets["europe"] + s.universe_buckets["asia"] %}
              {% if risky %}
              <div class="chip-row">
                {% for c in risky %}{{ chip_with_current(c, s.current_alloc_by_id) }}{% endfor %}
              </div>
              {% else %}
              <span class="dash">—</span>
              {% endif %}
            </td>
            <td class="chips">
              {% if s.previous_alloc %}
              <div class="chip-row">
                {% for c in s.previous_alloc %}{{ asset_chip(c, c.id ~ " " ~ c.pct ~ "%") }}{% endfor %}
              </div>
              {% else %}
              <span class="dash">—</span>
              {% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <h2>Equity curves</h2>
    <div class="panel">
      <div id="equity-chart" class="chart"></div>
    </div>

    <h2>Performance metrics</h2>
    <div class="panel">
      <table class="metrics">
        <thead>
          <tr>
            <th class="sortable" data-sort="text">Strategy</th>
            <th class="numeric sortable sort-desc" data-sort="num" title="Default sort key: rows pre-sorted by CAGR desc; click any other sortable header to re-rank.">CAGR</th>
            <th class="numeric sortable" data-sort="num">Vol (ann.)</th>
            <th class="numeric sortable" data-sort="num">Sharpe</th>
            <th class="numeric sortable" data-sort="num">Sortino</th>
            <th class="numeric sortable" data-sort="num">Max DD</th>
            <th class="numeric sortable" data-sort="num">Calmar</th>
            <th class="numeric sortable" data-sort="num" title="Daily hit rate: fraction of trading days with positive return. Correlated with vol more than skill — see Rebal hit for the slow-strategy-relevant view.">Daily hit</th>
            <th class="numeric sortable" data-sort="num" title="Per-rebalance hit rate: fraction of rebalance intervals where the equity at the next rebalance is above the equity at the current one. Sample size = number of rebalances, so this is the meaningful skill measure for monthly/weekly strategies.">Rebal hit</th>
            <th class="numeric sortable" data-sort="num" title="Annualised L1 turnover: sum of per-rebalance turnovers / years. Directly drives total transaction-cost drag at fixed per-trade cost.">Turnover/yr</th>
            <th class="numeric sortable" data-sort="num">Final</th>
            <th class="numeric sortable" data-sort="num" title="Cumulative transaction cost (sum of turnover × per-trade pct over the full backtest). Same units as Final — Final + Total cost ≈ no-cost final equity.">Total cost</th>
            <th class="numeric sortable" data-sort="num" title="Average pairwise Pearson correlation of daily returns across the strategy's risky universe. Lower = more decorrelated = better diversification potential.">Avg corr</th>
          </tr>
        </thead>
        <tbody>
          {% for m in metrics_rows %}
          <tr>
            <td data-value="{{ m.name }}"><span class="pill">{{ m.name }}</span></td>
            <td class="numeric {{ 'pos' if m.cagr >= 0 else 'neg' }}" data-value="{{ m.cagr }}">{{ "%.2f%%"|format(m.cagr * 100) }}</td>
            <td class="numeric" data-value="{{ m.vol_ann }}">{{ "%.2f%%"|format(m.vol_ann * 100) }}</td>
            <td class="numeric" data-value="{{ m.sharpe }}">{{ "%.2f"|format(m.sharpe) }}</td>
            <td class="numeric" data-value="{{ m.sortino }}">{{ "%.2f"|format(m.sortino) }}</td>
            <td class="numeric neg" data-value="{{ m.max_drawdown }}">{{ "%.2f%%"|format(m.max_drawdown * 100) }}</td>
            <td class="numeric" data-value="{{ m.calmar }}">{{ "%.2f"|format(m.calmar) }}</td>
            <td class="numeric" data-value="{{ m.hit_rate }}">{{ "%.1f%%"|format(m.hit_rate * 100) }}</td>
            <td class="numeric" data-value="{% if m.rebalance_hit_rate is not none %}{{ m.rebalance_hit_rate }}{% else %}-999{% endif %}">{% if m.rebalance_hit_rate is not none %}{{ "%.1f%%"|format(m.rebalance_hit_rate * 100) }}{% else %}—{% endif %}</td>
            <td class="numeric" data-value="{% if m.turnover_per_year is not none %}{{ m.turnover_per_year }}{% else %}-999{% endif %}">{% if m.turnover_per_year is not none %}{{ "%.2f"|format(m.turnover_per_year) }}{% else %}—{% endif %}</td>
            <td class="numeric" data-value="{{ m.final_equity }}">{{ "%.3f"|format(m.final_equity) }}</td>
            <td class="numeric neg" data-value="{{ m.total_cost }}">{{ "%.3f"|format(m.total_cost) }}</td>
            <td class="numeric" data-value="{% if m.avg_corr is not none %}{{ m.avg_corr }}{% else %}-999{% endif %}">{% if m.avg_corr is not none %}{{ "%.2f"|format(m.avg_corr) }}{% else %}—{% endif %}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <h2>Drawdown</h2>
    <div class="panel">
      <div id="drawdown-chart" class="chart"></div>
    </div>

    <footer>
      <p>
        Powered by polars · plotly · yfinance · ECB €STR.
        Synthetic price for safe asset compounded from €STR daily fixings (ACT/360).
        Backtest applies {{ summary.cost_bps }}bps one-way cost on turnover.
      </p>
    </footer>
  </div>

  <script>
    Plotly.newPlot(
      "equity-chart",
      {{ equity_traces | safe }},
      {{ equity_layout | safe }},
      { responsive: true, displaylogo: false }
    );
    Plotly.newPlot(
      "drawdown-chart",
      {{ drawdown_traces | safe }},
      {{ drawdown_layout | safe }},
      { responsive: true, displaylogo: false }
    );

    // Click-to-sort on table headers. Applies to any table with .sortable
    // headers (signal table + metrics table). Single click toggles asc/desc.
    document.querySelectorAll("table.metrics, table.signal").forEach(table => {
      const ths = Array.from(table.querySelectorAll("th.sortable"));
      const tbody = table.querySelector("tbody");
      ths.forEach((th, idx) => {
        // Skip non-sortable columns (chip cells in the signal table) - they
        // have no .sortable class and won't enter this loop.
        const headerCells = Array.from(table.querySelectorAll("thead th"));
        const colIdx = headerCells.indexOf(th);
        th.addEventListener("click", () => {
          const wasDesc = th.classList.contains("sort-desc");
          ths.forEach(x => x.classList.remove("sort-asc", "sort-desc"));
          th.classList.add(wasDesc ? "sort-asc" : "sort-desc");
          const asc = !wasDesc;
          const rows = Array.from(tbody.querySelectorAll("tr"));
          const isText = th.dataset.sort === "text";
          rows.sort((a, b) => {
            const av = a.children[colIdx].dataset.value || "";
            const bv = b.children[colIdx].dataset.value || "";
            if (isText) {
              return asc ? av.localeCompare(bv) : bv.localeCompare(av);
            }
            return asc ? parseFloat(av) - parseFloat(bv) : parseFloat(bv) - parseFloat(av);
          });
          rows.forEach(r => tbody.appendChild(r));
        });
      });
    });
  </script>
</body>
</html>
