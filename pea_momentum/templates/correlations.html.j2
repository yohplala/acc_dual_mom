<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>PEA-eligible universe — correlation matrix</title>
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
  <style>
    :root {
      --bg: #0e1116; --panel: #161b22; --border: #30363d;
      --text: #e6edf3; --muted: #8b949e; --accent: #58a6ff;
      --positive: #3fb950; --negative: #f85149;
    }
    html, body {
      background: var(--bg); color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
      margin: 0; padding: 0;
    }
    .container { max-width: 1400px; margin: 0 auto; padding: 24px; }
    h1 { margin: 0 0 4px 0; font-size: 28px; }
    h2 { margin: 32px 0 12px 0; font-size: 20px; border-bottom: 1px solid var(--border); padding-bottom: 6px; }
    .subtitle { color: var(--muted); margin-bottom: 24px; font-size: 13px; }
    .panel {
      background: var(--panel); border: 1px solid var(--border);
      border-radius: 6px; padding: 16px; margin-bottom: 16px;
    }
    .heatmap { height: 800px; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th, td { text-align: left; padding: 8px 12px; border-bottom: 1px solid var(--border); vertical-align: top; }
    th { color: var(--muted); font-weight: 500; text-transform: uppercase; font-size: 11px; letter-spacing: 0.5px; }
    td.numeric { text-align: right; font-variant-numeric: tabular-nums; }
    .pill {
      display: inline-block; background: rgba(88, 166, 255, 0.15); color: var(--accent);
      padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 500;
    }
    .pill.rep { background: rgba(63, 185, 80, 0.18); color: var(--positive); }
    .members { color: var(--muted); font-size: 12px; }
    nav a { color: var(--accent); text-decoration: none; margin-right: 16px; }
    nav a:hover { text-decoration: underline; }
    footer { margin-top: 48px; color: var(--muted); font-size: 12px; text-align: center; }
  </style>
</head>
<body>
  <div class="container">
    <h1>PEA-eligible universe — correlation matrix</h1>
    <div class="subtitle">
      {{ summary.n_assets }} assets · pairwise Pearson correlation of daily returns over the
      trailing {{ summary.window_days }} business days · last update {{ summary.last_update }}
    </div>
    <nav><a href="index.html">← Strategy dashboard</a></nav>

    <h2>Correlation heatmap</h2>
    <div class="panel">
      <div id="heatmap" class="heatmap"></div>
      <p style="color: var(--muted); font-size: 12px; margin-top: 12px;">
        Triangular display (lower triangle). Bright red = highly correlated (≥ 0.95);
        white ≈ uncorrelated; bright blue = inversely correlated. Hover over a cell
        to see the exact value.
      </p>
    </div>

    <h2>Redundancy groups (correlation > {{ "%.2f"|format(summary.threshold) }})</h2>
    <div class="panel">
      {% if groups %}
      <table>
        <thead>
          <tr>
            <th>Group size</th>
            <th>Best in group</th>
            <th>Score (CAGR / TER)</th>
            <th>All members</th>
          </tr>
        </thead>
        <tbody>
          {% for g in groups %}
          <tr>
            <td>{{ g.group|length }}</td>
            <td><span class="pill rep">{{ g.representative }}</span></td>
            <td class="numeric">{{ "%.2f"|format(g.representative_score) }}</td>
            <td class="members">
              {% for m in g.group %}{% if m != g.representative %}<span class="pill">{{ m }}</span> {% endif %}{% endfor %}
              {% if g.group|length == 1 %}<em>(singleton)</em>{% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      <p style="color: var(--muted); font-size: 12px; margin-top: 12px;">
        Representative pick: highest CAGR / TER ratio over the same window. Use it to
        choose one member per group when constructing strategy universes — picking
        multiple from the same group adds no diversification.
      </p>
      {% else %}
      <p style="color: var(--muted);">No data — run <code>pea-mom discover</code> first.</p>
      {% endif %}
    </div>

    <footer>
      <p>
        Universe: every Amundi PEA-eligible UCITS ETF with a known Yahoo ticker.
        EUR-only, leveraged / inverse ETFs excluded.
      </p>
    </footer>
  </div>

  <script>
    Plotly.newPlot(
      "heatmap",
      {{ heatmap_traces | safe }},
      {{ heatmap_layout | safe }},
      { responsive: true, displaylogo: false }
    );
  </script>
</body>
</html>
